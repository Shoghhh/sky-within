# Sky Within - Backend Environment Variables
# Copy to .env and fill in values

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/sky_within_db?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# OpenAI (for AI-generated daily messages)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Firebase Cloud Messaging (optional)
GOOGLE_APPLICATION_CREDENTIALS="/path/to/firebase-service-account.json"

# AstroAPI (optional - for natal chart images and professional interpretations)
# Get a key at https://astroapi.cloud - enables chart wheel image and AstroAPI interpretations
ASTROAPI_KEY=""
